# Copy this file to key.properties in the same folder (android/) and fill in real values.
# key.properties is gitignored — never commit it.
#
# 1) Generate a keystore (interactive):
#    ./create_release_keystore.sh
#    Or manually:
#    keytool -genkeypair -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# 2) Copy this file:  cp key.properties.example key.properties
# 3) Set storePassword / keyPassword to match what you used with keytool.
#
# 4) Add the release SHA-1 and SHA-256 to Firebase:
#    ./gradlew :app:signingReport
#    (Use the "Variant: release" / "Config: release" section after key.properties exists.)
#
# Play App Signing: also add SHA fingerprints from Play Console → Release → App integrity.

storePassword=your-keystore-password
keyPassword=your-key-password
keyAlias=upload
storeFile=upload-keystore.jks
