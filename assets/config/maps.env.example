# Maps SDK (AndroidManifest / iOS plist) — can use Android/iOS app restrictions.
GOOGLE_MAPS_API_KEY_ANDROID=
GOOGLE_MAPS_API_KEY_IOS=
GOOGLE_MAPS_API_KEY_WEB=

# Geocoding + Places Autocomplete (legacy HTTP from the app). Use a SEPARATE key:
# Google Cloud → Credentials → Create key → Application restrictions: None
# → API restrictions: Places API + Geocoding API only.
# (Android app–restricted keys often fail for plain http.get — same "empty referer" error.)
GOOGLE_MAPS_WEB_SERVICES_KEY=
